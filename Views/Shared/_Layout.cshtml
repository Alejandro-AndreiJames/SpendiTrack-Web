@{
    var userThemeKey = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "guest";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    string NavLinkClass(string controller, string action = "Index", bool controllerOnly = false)
    {
        var isActive = controllerOnly
            ? string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
            : string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
              && string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);
        return isActive ? "nav-link active" : "nav-link";
    }
}
<!DOCTYPE html>
<html lang="en" data-theme="classic" data-user-theme-key="@userThemeKey">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SpendiTrack</title>
    <link rel="icon" type="image/svg+xml" sizes="any" href="~/SpendiTrackIcon.svg" asp-append-version="true" />
    <link rel="alternate icon" type="image/svg+xml" href="~/SpendiTrackIcon.svg" asp-append-version="true" />
    <script>
        (function () {
            try {
                var el = document.documentElement;
                var userKey = el.dataset.userThemeKey || 'guest';
                var saved = localStorage.getItem('spenditrack.theme.' + userKey);
                el.setAttribute('data-theme', saved || 'classic');
            } catch (e) { }
        })();
    </script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/SpendiTrackWeb.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/themes.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body data-user-theme-key="@userThemeKey">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark navbar-spenditrack mb-4">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">SpendiTrack</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="@NavLinkClass("Home", "Index")" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavLinkClass("Expenses", controllerOnly: true)" asp-controller="Expenses" asp-action="Index">Tracker</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavLinkClass("Home", "About")" asp-controller="Home" asp-action="About">About</a>
                        </li>
                        <partial name="_ThemePicker" />
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-spenditrack fixed-bottom">
        <div class="container text-center">
            &copy; @DateTime.Now.Year SpendiTrack — Track spending. Stay in control.
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/theme.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
