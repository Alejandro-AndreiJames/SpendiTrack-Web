@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@{
    ViewData["Title"] = "Home";
}

<!-- Hero section -->
<section class="hero-section">
    <h1>SpendiTrack</h1>
    <p class="tagline">Your personal expenditure tracker and budget calculator. Record spending, see summaries, and plan what you can afford.</p>
    <div class="action-links">
        @if (SignInManager.IsSignedIn(User))
        {
            <a asp-controller="Expenses" asp-action="Index" class="btn btn-gold btn-lg">Go to Tracker</a>
        }
        else
        {
            <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-gold btn-lg">Get Started</a>
        }
    </div>
</section>

<!-- Sample budget calculator -->
<div class="row g-4 home-feature-row">
    <div class="col-lg-6">
        <div class="calculator-panel h-100">
            <h3>Budget calculator</h3>
            <p class="help-text mb-3">Estimate how much you can spend daily and weekly after savings and fixed bills.</p>
            <form id="budget-calculator-form">
                <div class="mb-3">
                    <label class="form-label" for="monthly-income">Monthly income</label>
                    <input type="number" class="form-control" id="monthly-income" min="0" step="0.01" placeholder="e.g. 3500" required />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="savings-percent">Savings goal (%)</label>
                    <input type="number" class="form-control" id="savings-percent" min="0" max="100" step="1" value="10" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="fixed-costs">Fixed monthly costs (rent, bills)</label>
                    <input type="number" class="form-control" id="fixed-costs" min="0" step="0.01" placeholder="e.g. 1200" />
                </div>
                <button type="submit" class="btn btn-gold w-100">Calculate budget</button>
            </form>
            <div id="budget-calculator-results" class="calculator-result" style="display: none;"></div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="form-panel home-how-it-works h-100">
            <h2 class="h5 mb-3 home-how-it-works__title">How it works</h2>
            <div class="home-feature-grid">
                <div class="home-feature-item">
                    <strong>Tracker</strong>
                    <span>View expenses with monthly totals, averages, and category breakdown.</span>
                </div>
                <div class="home-feature-item">
                    <strong>Add / Edit</strong>
                    <span>Sign in to create or update entries — ASP.NET Identity keeps your data secure.</span>
                </div>
                <div class="home-feature-item">
                    <strong>Search</strong>
                    <span>Filter transaction history by description keyword on the Tracker page.</span>
                </div>
                <div class="home-feature-item">
                    <strong>Monthly budget</strong>
                    <span>Set income, savings, fixed costs, and per-category spending limits.</span>
                </div>
                <div class="home-feature-item">
                    <strong>Themes</strong>
                    <span>Pick a color palette from the navbar — your choice is saved per account.</span>
                </div>
                <div class="home-feature-item">
                    <strong>Calculator</strong>
                    <span>Use the tool on this page to plan disposable income before you spend.</span>
                </div>
            </div>
        </div>
    </div>
</div>
