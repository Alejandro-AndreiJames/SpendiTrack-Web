@{
    var budgetLimitError = ViewContext.ModelState["CategoryBudgetLimit"]?.Errors.FirstOrDefault()?.ErrorMessage;
}
@if (!string.IsNullOrWhiteSpace(budgetLimitError))
{
    <div class="expense-form-notice expense-form-notice--budget-limit expense-budget-limit-notice" role="alert">
        <span class="expense-form-notice__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="8" x2="12" y2="12"></line>
                <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
        </span>
        <div class="expense-form-notice__copy">
            <strong class="expense-form-notice__title">Category budget limit</strong>
            <p class="expense-form-notice__message mb-0">@budgetLimitError</p>
        </div>
    </div>
}
