@model SpendiTrackWeb.Models.Expense

@{
    ViewData["Title"] = "Expense Details";
}

<div class="page-header">
    <h1>Expense details</h1>
</div>

<div class="row">
    <div class="col-md-6">
        <dl class="detail-card">
            <dt>Description</dt>
            <dd>@Model.Description</dd>
            <dt>Amount</dt>
            <dd class="amount">@Model.Amount.ToString("C")</dd>
            <dt>Date</dt>
            <dd>@Model.Date.ToString("MMMM d, yyyy")</dd>
            <dt>Category</dt>
            <dd>@Model.Category</dd>
        </dl>
        <div class="mt-3">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-gold">Edit</a>
            <a asp-action="Index" class="btn btn-outline-gold ms-2">Back to tracker</a>
        </div>
    </div>
</div>
