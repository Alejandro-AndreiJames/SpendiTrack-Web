@model SpendiTrackWeb.Models.Expense
@using SpendiTrackWeb.Models
@using System.Globalization

@{
    var amountValue = Model.Amount > 0
        ? Model.Amount.ToString(CultureInfo.InvariantCulture)
        : string.Empty;
}

<div class="modal fade" id="addExpenseModal" tabindex="-1" aria-labelledby="addExpenseModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered expense-modal__dialog">
        <div class="modal-content expense-modal">
            <div class="modal-header">
                <h2 class="modal-title h5 mb-0" id="addExpenseModalLabel" style="color: var(--gold);">Add expense</h2>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Create" method="post" id="addExpenseForm" novalidate>
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="add-expense-field">
                        <label asp-for="Description" class="form-label"></label>
                        <input asp-for="Description" class="form-control" id="AddExpense_Description" placeholder="What did you spend on?" autocomplete="off" />
                        <div class="form-field-foot">
                            <span asp-validation-for="Description"></span>
                        </div>
                    </div>
                    <div class="add-expense-field">
                        <label asp-for="Amount" class="form-label"></label>
                        <input name="Amount"
                               id="AddExpense_Amount"
                               value="@amountValue"
                               class="form-control"
                               type="number"
                               step="0.01"
                               placeholder="0.00"
                               inputmode="decimal"
                               autocomplete="off"
                               data-val="true"
                               data-val-required="Enter an amount."
                               data-val-number="Enter a valid amount."
                               data-val-range="Amount must be at least ₱0.01."
                               data-val-range-min="0.01"
                               data-val-range-max="79228162514264337593543950335" />
                        <div class="form-field-foot">
                            <span asp-validation-for="Amount"></span>
                        </div>
                    </div>
                    <div class="add-expense-field">
                        <label asp-for="Date" class="form-label"></label>
                        <input asp-for="Date" class="form-control" type="date" id="AddExpense_Date" />
                        <div class="form-field-foot">
                            <span asp-validation-for="Date"></span>
                        </div>
                    </div>
                    <div class="add-expense-field add-expense-field--last">
                        <label asp-for="Category" class="form-label"></label>
                        <div class="spendi-select" data-spendi-select>
                            <select asp-for="Category" class="spendi-select__native" id="AddExpense_Category" required tabindex="-1" aria-hidden="true">
                                <option value="">Select category</option>
                                @foreach (var cat in ExpenseCategories.All)
                                {
                                    <option value="@cat">@cat</option>
                                }
                            </select>
                            <button type="button" class="spendi-select__trigger" aria-haspopup="listbox" aria-expanded="false">
                                <span class="spendi-select__value" data-placeholder="Select category">Select category</span>
                            </button>
                            <ul class="spendi-select__menu" role="listbox" hidden>
                                @foreach (var cat in ExpenseCategories.All)
                                {
                                    <li class="spendi-select__option" role="option" data-value="@cat">@cat</li>
                                }
                            </ul>
                        </div>
                        <div class="form-field-foot">
                            <span asp-validation-for="Category"></span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-gold" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-gold">Save expense</button>
                </div>
            </form>
        </div>
    </div>
</div>
