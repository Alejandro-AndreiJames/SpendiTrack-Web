@{
    ViewData["Title"] = "Search Expenses";
}

<div class="page-header">
    <h1>Search expenses</h1>
    <p class="lead">Find transactions by description.</p>
</div>

<div class="row">
    <div class="col-md-6 col-lg-5">
        <div class="form-panel">
            <form asp-action="ShowSearchResults" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label for="searchPhrase" class="form-label">Description contains</label>
                    <input name="searchPhrase" id="searchPhrase" class="form-control" placeholder="e.g. groceries, gas" />
                </div>
                <button type="submit" class="btn btn-gold">Search</button>
                <a asp-action="Index" class="btn btn-outline-gold ms-2">View all</a>
            </form>
        </div>
    </div>
</div>
