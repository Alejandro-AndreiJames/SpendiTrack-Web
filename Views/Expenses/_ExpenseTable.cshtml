@model IEnumerable<SpendiTrackWeb.Models.Expense>

<div class="table-responsive">
    <table class="table table-spenditrack table-striped table-hover mb-0">
        <thead>
            <tr>
                <th>Description</th>
                <th>Amount</th>
                <th>Date</th>
                <th>Category</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Description</td>
                    <td class="amount-cell">@item.Amount.ToString("C")</td>
                    <td>@item.Date.ToString("MMM d, yyyy")</td>
                    <td><span class="badge rounded-pill" style="background: rgba(212,175,55,0.2); color: var(--gold-light);">@item.Category</span></td>
                    <td class="text-end text-nowrap">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-gold">View</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-gold">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger-soft">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
