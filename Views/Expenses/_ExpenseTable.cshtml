@model IEnumerable<SpendiTrackWeb.Models.Expense>
@using System.Globalization

<div class="expense-list">
    @foreach (var item in Model)
    {
        <article class="expense-card"
                 data-expense-id="@item.Id"
                 data-expense-description="@item.Description"
                 data-expense-amount="@item.Amount.ToString(CultureInfo.InvariantCulture)"
                 data-expense-date="@item.Date.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)"
                 data-expense-category="@item.Category">
            <div class="expense-card__body">
                <h3 class="expense-card__title">@item.Description</h3>
                <div class="expense-card__meta">
                    <span class="expense-card__date">@item.Date.ToString("MMM d, yyyy")</span>
                    <span class="expense-card__dot" aria-hidden="true">·</span>
                    <span class="expense-card__category">@item.Category</span>
                </div>
            </div>
            <div class="expense-card__aside">
                <span class="expense-card__amount">@item.Amount.ToString("C")</span>
                <div class="expense-card__actions">
                    <button type="button" class="btn btn-sm btn-outline-gold" data-expense-action="view">View</button>
                    <button type="button" class="btn btn-sm btn-outline-gold" data-expense-action="edit">Edit</button>
                    <button type="button" class="btn btn-sm btn-danger-soft" data-expense-action="delete">Delete</button>
                </div>
            </div>
        </article>
    }
</div>
