@model IEnumerable<SpendiTrackWeb.Models.Expense>
@using System.Globalization

<div class="expense-list">
    @foreach (var item in Model)
    {
        <article class="expense-card"
                 data-expense-id="@item.Id"
                 data-expense-description="@item.Description"
                 data-expense-amount="@item.Amount.ToString(CultureInfo.InvariantCulture)"
                 data-expense-date="@item.Date.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)"
                 data-expense-category="@item.Category">
            <div class="expense-card__body">
                <h3 class="expense-card__title">@item.Description</h3>
                <div class="expense-card__meta">
                    <span class="expense-card__date">@item.Date.ToString("MMM d, yyyy")</span>
                    <span class="expense-card__dot" aria-hidden="true">·</span>
                    <span class="expense-card__category">@item.Category</span>
                </div>
                <span class="expense-card__amount expense-card__amount--stacked">@item.Amount.ToString("C")</span>
            </div>
            <div class="expense-card__aside">
                <span class="expense-card__amount expense-card__amount--aside">@item.Amount.ToString("C")</span>
                <div class="dropdown expense-card__menu">
                    <button type="button"
                            class="btn btn-sm btn-outline-gold expense-card__menu-toggle"
                            id="expenseMenuToggle_@item.Id"
                            data-bs-toggle="dropdown"
                            data-bs-auto-close="true"
                            data-bs-popper-config='{"strategy":"fixed"}'
                            aria-expanded="false"
                            aria-haspopup="true"
                            aria-label="More actions"
                            title="More actions">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <circle cx="12" cy="5" r="1.75"></circle>
                            <circle cx="12" cy="12" r="1.75"></circle>
                            <circle cx="12" cy="19" r="1.75"></circle>
                        </svg>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end expense-card__menu-list"
                        aria-labelledby="expenseMenuToggle_@item.Id"
                        role="menu">
                        <li role="none">
                            <button type="button" class="dropdown-item expense-card__menu-item expense-card__menu-item--view" data-expense-action="view" role="menuitem">View</button>
                        </li>
                        <li role="none">
                            <button type="button" class="dropdown-item expense-card__menu-item expense-card__menu-item--edit" data-expense-action="edit" role="menuitem">Edit</button>
                        </li>
                        <li role="none">
                            <button type="button" class="dropdown-item expense-card__menu-item expense-card__menu-item--duplicate" data-expense-action="duplicate" role="menuitem">Duplicate</button>
                        </li>
                        <li role="none"><hr class="dropdown-divider"></li>
                        <li role="none">
                            <button type="button" class="dropdown-item expense-card__menu-item expense-card__menu-item--delete" data-expense-action="delete" role="menuitem">Delete</button>
                        </li>
                    </ul>
                </div>
                <div class="expense-card__actions">
                    <button type="button"
                            class="btn btn-sm expense-action-btn expense-action-btn--view"
                            data-expense-action="view"
                            title="View"
                            aria-label="View">
                        <span class="expense-action-btn__text">View</span>
                    </button>
                    <button type="button"
                            class="btn btn-sm expense-action-btn expense-action-btn--edit"
                            data-expense-action="edit"
                            title="Edit"
                            aria-label="Edit">
                        <span class="expense-action-btn__text">Edit</span>
                    </button>
                    <button type="button"
                            class="btn btn-sm expense-action-btn expense-action-btn--duplicate"
                            data-expense-action="duplicate"
                            title="Duplicate: copy into a new expense for today"
                            aria-label="Duplicate">
                        <span class="expense-action-btn__text">Duplicate</span>
                    </button>
                    <button type="button"
                            class="btn btn-sm expense-action-btn expense-action-btn--delete"
                            data-expense-action="delete"
                            title="Delete"
                            aria-label="Delete">
                        <svg class="expense-action-btn__icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <polyline points="3 6 5 6 21 6"></polyline>
                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                            <line x1="10" y1="11" x2="10" y2="17"></line>
                            <line x1="14" y1="11" x2="14" y2="17"></line>
                        </svg>
                        <span class="expense-action-btn__text">Delete</span>
                    </button>
                </div>
            </div>
        </article>
    }
</div>
