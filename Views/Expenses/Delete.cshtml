@model SpendiTrackWeb.Models.Expense

@{
    ViewData["Title"] = "Delete Expense";
}

<div class="page-header">
    <h1>Delete expense</h1>
    <p class="lead text-danger">This action cannot be undone.</p>
</div>

<div class="row">
    <div class="col-md-6">
        <dl class="detail-card">
            <dt>Description</dt>
            <dd>@Model.Description</dd>
            <dt>Amount</dt>
            <dd class="amount">@Model.Amount.ToString("C")</dd>
            <dt>Date</dt>
            <dd>@Model.Date.ToString("MMMM d, yyyy")</dd>
            <dt>Category</dt>
            <dd>@Model.Category</dd>
        </dl>
        <form asp-action="Delete" class="mt-3">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger-soft">Confirm delete</button>
            <a asp-action="Index" class="btn btn-outline-gold ms-2">Cancel</a>
        </form>
    </div>
</div>
