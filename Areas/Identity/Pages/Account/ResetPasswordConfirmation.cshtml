@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Password reset";
}

@if (Model.Succeeded)
{
    var landing = new SpendiTrackWeb.Models.AuthSuccessLandingViewModel
    {
        Title = "Password updated",
        Lead = string.IsNullOrWhiteSpace(Model.DisplayName)
            ? "Your password has been reset successfully."
            : $"Your password is updated, {Model.DisplayName}.",
        StatusText = "Logging you in",
        RedirectUrl = Model.RedirectUrl,
        ContinueLabel = "Continue now"
    };
    <partial name="_AuthSuccessLanding" model="landing" />
}
else
{
    <h1>@ViewData["Title"]</h1>
    <p>
        Your password has been reset.
        <a asp-page="./Login">Click here to log in</a>.
    </p>
}
