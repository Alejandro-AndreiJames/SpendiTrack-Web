@page
@model SpendiTrackWeb.Areas.Identity.Pages.Account.Manage.ChangePasswordModel
@{
    ViewData["Title"] = Model.Succeeded ? "Password changed" : "Password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;

    if (Model.Succeeded)
    {
        Layout = "/Views/Shared/_Layout.cshtml";
    }
}

@if (Model.Succeeded)
{
    var landing = new SpendiTrackWeb.Models.AuthSuccessLandingViewModel
    {
        Title = "Password changed",
        Lead = string.IsNullOrWhiteSpace(Model.DisplayName)
            ? "Your password has been updated successfully."
            : $"All set, {Model.DisplayName}. Your password is updated.",
        StatusText = "Taking you back",
        RedirectUrl = Model.RedirectUrl,
        ContinueLabel = "Continue now"
    };
    <partial name="_AuthSuccessLanding" model="landing" />
}
else
{
    <div class="manage-section">
        <header class="manage-section__head">
            <h2 class="manage-section__title">Password</h2>
            <p class="manage-section__lead">Choose a strong password you don’t use elsewhere.</p>
        </header>

        <form id="change-password-form" method="post" class="manage-form">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="manage-field">
                <label class="manage-field__label" asp-for="Input.OldPassword">Current password</label>
                <input asp-for="Input.OldPassword" class="manage-field__input" autocomplete="current-password" />
                <span asp-validation-for="Input.OldPassword" class="text-danger"></span>
            </div>

            <div class="manage-field">
                <label class="manage-field__label" asp-for="Input.NewPassword">New password</label>
                <input asp-for="Input.NewPassword" class="manage-field__input" autocomplete="new-password" />
                <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
            </div>

            <div class="manage-field">
                <label class="manage-field__label" asp-for="Input.ConfirmPassword">Confirm new password</label>
                <input asp-for="Input.ConfirmPassword" class="manage-field__input" autocomplete="new-password" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="manage-form__actions">
                <button type="submit" class="btn btn-gold">Update password</button>
            </div>
        </form>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
