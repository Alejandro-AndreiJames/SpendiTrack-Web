@page
@model ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = "Forgot password confirmation";
}

<h1>@ViewData["Title"]</h1>

@if (Model.DisplayResetLink && !string.IsNullOrEmpty(Model.PasswordResetUrl))
{
    <p>
        SMTP is not configured, so reset mail was saved under <code>App_Data/emails</code>.
        You can also reset now by
        <a href="@Model.PasswordResetUrl">clicking here</a>.
    </p>
}
else
{
    <p>
        Please check your email for a link to reset your password.
    </p>
}
